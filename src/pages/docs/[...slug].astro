---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getCollection, render } from "astro:content";

const docs = await getCollection("docs");

const slug = Astro.params.slug;
const currentPath = Array.isArray(slug) ? slug.join("/") : slug;

const doc = docs.find((entry) => entry.id === currentPath);

if (!doc) {
  throw new Error(`Doc not found: ${currentPath}`);
}

const { Content } = await render(doc);
---

<DocsLayout title={doc.data.title} description={doc.data.description}>
  <section class="docs-article">
    <Content />
  </section>
</DocsLayout>
