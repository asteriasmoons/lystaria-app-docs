---
import BaseLayout from "./BaseLayout.astro";
import { getCollection } from "astro:content";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const docs = await getCollection("docs");
const currentPath = Astro.url.pathname;

const sectionOrder = ["Getting Started", "Core Features", "Other"];

type DocEntry = (typeof docs)[number];

type NavNode = {
  doc: DocEntry;
  href: string;
  isAnchor: boolean;
  isActive: boolean;
  isOpen: boolean;
  children: NavNode[];
};

const getHref = (doc: DocEntry) => `/docs/${doc.id}`;

const isDocActive = (doc: DocEntry) => currentPath === getHref(doc);

const sortDocs = (items: DocEntry[]) =>
  [...items].sort((a, b) => {
    const orderA = a.data.order ?? 999;
    const orderB = b.data.order ?? 999;

    if (orderA !== orderB) return orderA - orderB;
    return a.data.title.localeCompare(b.data.title);
  });

const buildTree = (items: DocEntry[], parent?: string): NavNode[] => {
  const children = sortDocs(
    items.filter((doc) =>
      parent ? doc.data.parent === parent : !doc.data.parent,
    ),
  );

  return children.map((doc) => {
    const nestedChildren = buildTree(items, doc.id);
    const active = isDocActive(doc);
    const childActive = nestedChildren.some(
      (child) => child.isActive || child.isOpen,
    );

    return {
      doc,
      href: getHref(doc),
      isAnchor: Boolean(doc.data.isAnchor),
      isActive: active,
      isOpen: active || childActive,
      children: nestedChildren,
    };
  });
};

const groupedDocsMap = docs.reduce(
  (acc, doc) => {
    const section = doc.data.section ?? "Other";
    if (!acc[section]) acc[section] = [];
    acc[section].push(doc);
    return acc;
  },
  {} as Record<string, typeof docs>,
);

const groupedDocs = Object.entries(groupedDocsMap)
  .sort(([a], [b]) => {
    const aIndex = sectionOrder.indexOf(a);
    const bIndex = sectionOrder.indexOf(b);

    if (aIndex === -1 && bIndex === -1) return a.localeCompare(b);
    if (aIndex === -1) return 1;
    if (bIndex === -1) return -1;

    return aIndex - bIndex;
  })
  .map(([section, docsInSection]) => {
    return [section, buildTree(docsInSection)] as const;
  });
---

<BaseLayout {title} {description}>
  <div class="docs-shell">
    <div class="docs-backdrop" data-sidebar-backdrop></div>

    <aside class="sidebar-drawer" data-sidebar-drawer style="overflow-y: auto;">
      <div class="sidebar-top">
        <div class="sidebar-brand">
          <div class="sidebar-brand-icon">
            <img src="/favicon.svg" alt="Lystaria" />
          </div>
          <span class="sidebar-brand-title">Lystaria Docs</span>
        </div>

        <button
          type="button"
          class="sidebar-close"
          aria-label="Close navigation"
          data-sidebar-close
        >
          <img src="/img/icons/close.svg" alt="Close" class="sidebar-icon" />
        </button>
      </div>

      <div class="sidebar-nav">
        <div class="nav-group">
          <p class="nav-section">Overview</p>

          <ul class="nav-list">
            <li>
              <a
                href="/"
                class:list={{
                  "nav-link": true,
                  "nav-link-active": currentPath === "/",
                }}
              >
                <span class="nav-link-text">Home</span>
              </a>
            </li>
          </ul>
        </div>

        {
          groupedDocs.map(([section, items]) => (
            <div class="nav-group">
              <p class="nav-section">{section}</p>

              <ul class="nav-list">
                {items.map((item) => {
                  if (item.isAnchor) {
                    return (
                      <li class="nav-anchor-item">
                        <details class="nav-anchor-details" open={item.isOpen}>
                          <summary
                            class:list={{
                              "nav-link": true,
                              "nav-link-active": item.isActive,
                              "nav-anchor-summary": true,
                            }}
                          >
                            <span class="nav-link-text">
                              {item.doc.data.title}
                            </span>

                            <span class="nav-anchor-chevron">
                              <img
                                src="/img/icons/right.svg"
                                class="chevron-icon chevron-right"
                                alt=""
                              />
                              <img
                                src="/img/icons/down.svg"
                                class="chevron-icon chevron-down"
                                alt=""
                              />
                            </span>
                          </summary>

                          <div class="nav-anchor-body">
                            <a
                              href={item.href}
                              class:list={{
                                "nav-sublink": true,
                                "nav-sublink-active": item.isActive,
                              }}
                            >
                              Overview
                            </a>

                            {item.children.map((child) => {
                              if (child.isAnchor) {
                                return (
                                  <details
                                    class="nav-anchor-details nav-nested-anchor-details"
                                    open={child.isOpen}
                                  >
                                    <summary
                                      class:list={{
                                        "nav-sublink": true,
                                        "nav-sublink-active": child.isActive,
                                        "nav-anchor-summary": true,
                                        "nav-nested-summary": true,
                                      }}
                                    >
                                      <span class="nav-link-text">
                                        {child.doc.data.title}
                                      </span>

                                      <span class="nav-anchor-chevron">
                                        <img
                                          src="/img/icons/right.svg"
                                          class="chevron-icon chevron-right"
                                          alt=""
                                        />
                                        <img
                                          src="/img/icons/down.svg"
                                          class="chevron-icon chevron-down"
                                          alt=""
                                        />
                                      </span>
                                    </summary>

                                    <div class="nav-anchor-body nav-nested-anchor-body">
                                      <a
                                        href={child.href}
                                        class:list={{
                                          "nav-sublink": true,
                                          "nav-sublink-active": child.isActive,
                                        }}
                                      >
                                        Overview
                                      </a>

                                      {child.children.map((grandchild) => (
                                        <a
                                          href={grandchild.href}
                                          class:list={{
                                            "nav-sublink": true,
                                            "nav-sublink-active":
                                              grandchild.isActive,
                                          }}
                                        >
                                          {grandchild.doc.data.title}
                                        </a>
                                      ))}
                                    </div>
                                  </details>
                                );
                              }

                              return (
                                <a
                                  href={child.href}
                                  class:list={{
                                    "nav-sublink": true,
                                    "nav-sublink-active": child.isActive,
                                  }}
                                >
                                  {child.doc.data.title}
                                </a>
                              );
                            })}
                          </div>
                        </details>
                      </li>
                    );
                  }

                  return (
                    <li>
                      <a
                        href={item.href}
                        class:list={{
                          "nav-link": true,
                          "nav-link-active": item.isActive,
                        }}
                      >
                        <span class="nav-link-text">{item.doc.data.title}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }

        <div class="nav-group">
          <p class="nav-section">Legal</p>

          <ul class="nav-list">
            <li>
              <a
                href="/contact"
                class:list={{
                  "nav-link": true,
                  "nav-link-active": currentPath === "/contact",
                }}
              >
                <span class="nav-link-text">Contact</span>
              </a>
            </li>
            <li>
              <a
                href="/privacy-policy"
                class:list={{
                  "nav-link": true,
                  "nav-link-active": currentPath === "/privacy-policy",
                }}
              >
                <span class="nav-link-text">Privacy Policy</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </aside>

    <div class="docs-main">
      <header class="topbar">
        <div class="topbar-inner">
          <button
            type="button"
            class="sidebar-toggle"
            aria-label="Open navigation"
            data-sidebar-open
          >
            <img src="/img/icons/menu.svg" alt="Menu" class="sidebar-icon" />
          </button>

          <span class="topbar-title">{title ?? "Documentation"}</span>
        </div>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>
  </div>

  <script is:inline>
    if (typeof document !== "undefined") {
      const initSidebar = () => {
        const body = document.body;
        const openBtn = document.querySelector("[data-sidebar-open]");
        const closeBtn = document.querySelector("[data-sidebar-close]");
        const backdrop = document.querySelector("[data-sidebar-backdrop]");

        if (!openBtn || !closeBtn || !backdrop) return;

        const openSidebar = () => {
          body.classList.add("sidebar-open");
        };

        const closeSidebar = () => {
          body.classList.remove("sidebar-open");
        };

        openBtn.addEventListener("click", openSidebar);
        closeBtn.addEventListener("click", closeSidebar);
        backdrop.addEventListener("click", closeSidebar);

        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closeSidebar();
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSidebar);
      } else {
        initSidebar();
      }
    }
  </script>
</BaseLayout>
