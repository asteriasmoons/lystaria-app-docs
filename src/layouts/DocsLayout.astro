---
import BaseLayout from "./BaseLayout.astro";
import { getCollection } from "astro:content";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const docs = await getCollection("docs");

const sortedDocs = [...docs].sort((a, b) => {
  const sectionA = a.data.section ?? "Other";
  const sectionB = b.data.section ?? "Other";

  if (sectionA !== sectionB) {
    return sectionA.localeCompare(sectionB);
  }

  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;

  if (orderA !== orderB) {
    return orderA - orderB;
  }

  return a.data.title.localeCompare(b.data.title);
});

const groupedDocs = Object.entries(
  sortedDocs.reduce(
    (acc, doc) => {
      const section = doc.data.section ?? "Other";
      if (!acc[section]) acc[section] = [];
      acc[section].push(doc);
      return acc;
    },
    {} as Record<string, typeof sortedDocs>,
  ),
);

const currentPath = Astro.url.pathname;
---

<BaseLayout {title} {description}>
  <div class="docs-shell">
    <aside class="sidebar">
      <div class="sidebar-inner">
        <h2 class="logo">Lystaria Docs</h2>

        {
          groupedDocs.map(([section, docsInSection]) => (
            <div class="nav-group">
              <p class="nav-section">{section}</p>

              <ul>
                {docsInSection.map((doc) => {
                  const href = `/docs/${doc.id}`;
                  const isActive = currentPath === href;

                  return (
                    <li>
                      <a
                        href={href}
                        class:list={{
                          "nav-link": true,
                          "nav-link-active": isActive,
                        }}
                      >
                        {doc.data.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </div>
    </aside>

    <div class="docs-main">
      <header class="topbar">
        <div class="topbar-inner">
          <span class="topbar-title">{title ?? "Documentation"}</span>
        </div>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>
